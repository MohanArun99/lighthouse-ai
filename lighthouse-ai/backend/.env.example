# Lighthouse AI Backend Configuration

# Demo Mode (true = use mock data, false = use real APIs)
DEMO_MODE=true

# Server Configuration
PORT=8000

# API Keys (only needed if DEMO_MODE=false)
# GOOGLE_API_KEY=your_gemini_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here

# Database (optional, for future enhancements)
# DATABASE_URL=postgresql://user:password@localhost:5432/lighthouse