# Lighthouse AI - Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================================================
# DEMO MODE (Default: true)
# ============================================================================
# Set to "false" to enable real LLM API calls
# Set to "true" for demo mode with mock data
DEMO_MODE=true

# ============================================================================
# LLM PROVIDER (Default: mock)
# ============================================================================
# Options: gemini, openai, mock
# Only used when DEMO_MODE=false
LLM_PROVIDER=mock

# ============================================================================
# GEMINI API (Google AI)
# ============================================================================
# Get your API key from: https://makersuite.google.com/app/apikey
# Uncomment and fill in when using Gemini
# GEMINI_API_KEY=your-gemini-api-key-here

# ============================================================================
# OPENAI API (ChatGPT / GPT-4)
# ============================================================================
# Get your API key from: https://platform.openai.com/api-keys
# Uncomment and fill in when using OpenAI
# OPENAI_API_KEY=your-openai-api-key-here

# ============================================================================
# LIVE AGENT — Databricks Model Serving (Claude 3.7 Sonnet)
# ============================================================================
# Wires the Financial Hedge Strategist agent to a real LLM via Databricks
# Model Serving's OpenAI-compatible chat completions API. The agent uses the
# Claude skill at backend/claude_skill/financial_hedging/SKILL.md and the
# pure-Python calculators in that folder as tool calls.
#
# All other agents continue to use the scripted timeline. If the live call
# fails (timeout, network, malformed JSON, missing creds) the demo falls back
# to the scripted card automatically — it never breaks.
#
# To enable, uncomment all four lines below:
# DATABRICKS_HOST=https://<your-workspace>.cloud.databricks.com
# DATABRICKS_TOKEN=dapi...your-personal-access-token
# LIVE_AGENTS=Financial Hedge Strategist
# LIVE_MODEL=databricks-claude-3-7-sonnet
#
# Optional knobs:
# LIVE_AGENT_TIMEOUT_S=12        # per-agent budget (seconds)

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
PORT=8080
HOST=0.0.0.0
LOG_LEVEL=info

# ============================================================================
# CORS (for local development)
# ============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ============================================================================
# EXAMPLE CONFIGURATIONS
# ============================================================================

# Example 1: Demo Mode (Default)
# DEMO_MODE=true
# LLM_PROVIDER=mock

# Example 2: Using Gemini API
# DEMO_MODE=false
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=AIzaSy...your-key

# Example 3: Using OpenAI GPT-4
# DEMO_MODE=false
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...your-key

# ============================================================================
# NOTES
# ============================================================================
# - Demo mode works without any API keys
# - Demo mode uses realistic mock data
# - Real LLM mode requires valid API key
# - Gemini API is recommended (like Globot uses)
# - Free tier available for both Gemini and OpenAI
